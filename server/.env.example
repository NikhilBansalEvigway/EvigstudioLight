# PostgreSQL only — never use file: or sqlite URLs here.
# If server/data/*.db appears, nothing in the API reads it — safe to delete the file/folder.
# If Docker maps host port 5433 → container 5432, use :5433 below.
DATABASE_URL=postgresql://evigstudio:evigstudio@127.0.0.1:5432/evigstudio
JWT_SECRET=change-me-to-a-long-random-string-in-production
PORT=3001
NODE_ENV=development
# Optional: absolute path to Vite dist/ to serve UI on the same port as API
STATIC_ROOT=

# --- Local LLM (LM Studio or any OpenAI-compatible server on loopback / private LAN only) ---
# Air-gapped deployments: no outbound internet is required; the browser hits this API, which forwards to LM_STUDIO_URL.
LM_STUDIO_URL=http://127.0.0.1:1234
# Max parallel upstream LLM requests (tune with LM Studio + GPU capacity; ~20 LAN users often use 4–8).
LLM_MAX_CONCURRENT=6
# How long to wait in queue for a slot before HTTP 503 (milliseconds).
LLM_QUEUE_WAIT_MS=120000
# Upstream request timeout for each proxied call (0 = no AbortSignal timeout; streaming may run long).
LLM_UPSTREAM_TIMEOUT_MS=0
# If true, only signed-in team users may use /api/llm (session cookie; still fully offline).
LLM_REQUIRE_AUTH=false
